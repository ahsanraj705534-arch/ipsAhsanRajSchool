# Flask Configuration
SECRET_KEY=your-very-long-random-secret-key-here
WTF_CSRF_SECRET_KEY=another-random-key-for-csrf
FLASK_ENV=development

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=run-this-command: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"

# Database
# Leave blank locally to use the SQLite fallback at data/school.db.
# On Railway, set this as a reference variable like: ${{Postgres.DATABASE_URL}}
DATABASE_URL=
# Example PostgreSQL: DATABASE_URL=postgresql://user:password@host:port/database
# Example MySQL: DATABASE_URL=mysql+pymysql://user:password@host:port/database

# MySQL (optional)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_DB=school_db
