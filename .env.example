# Flask Configuration
SECRET_KEY=your-very-long-random-secret-key-here
WTF_CSRF_SECRET_KEY=another-random-key-for-csrf
FLASK_ENV=development

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=run-this-command: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('your-password'))"

# Database
# Local development: leave DATABASE_URL blank to use SQLite at data/school.db.
# Railway / production: add a Postgres service and set DATABASE_URL as a reference
# variable in the web service, for example: ${{Postgres.DATABASE_URL}}
DATABASE_URL=
# Example PostgreSQL: DATABASE_URL=postgresql://user:password@host:port/database

# Optional: set to 1 only if your PostgreSQL provider requires SSL.
DATABASE_SSL_REQUIRE=0

# MySQL (optional)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=user
MYSQL_PASSWORD=password
MYSQL_DB=school_db
